<?xml version="1.0"?>
<jxb:bindings version="3.0"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:jxb="https://jakarta.ee/xml/ns/jaxb"
  xmlns:xjc="http://java.sun.com/xml/ns/jaxb/xjc"
  xmlns:ci="http://jaxb.dev.java.net/plugin/code-injector"
  jxb:extensionBindingPrefixes="xjc ci"
  >

  <jxb:bindings schemaLocation="AllInOne.xsd">
    <!-- Совпадение имён -->
    <jxb:bindings node="//xs:complexType[@name='TRD_EXTRACTOR']">
      <jxb:class name="TRD_EXTRACTORT"/>
    </jxb:bindings>
  </jxb:bindings>

</jxb:bindings>