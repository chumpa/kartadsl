<?xml version="1.0"?>
<jxb:bindings version="2.1" 
              xmlns:jxb="http://java.sun.com/xml/ns/jaxb"
              xmlns:xs="http://www.w3.org/2001/XMLSchema">

  <jxb:bindings schemaLocation="AllInOne.xsd">
    <!-- Совпадение имён -->
    <jxb:bindings node="//xs:complexType[@name='TRD_EXTRACTOR']">
      <jxb:class name="TRD_EXTRACTORT"/>
    </jxb:bindings>
  </jxb:bindings>

</jxb:bindings>