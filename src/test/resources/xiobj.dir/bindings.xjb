<jxb:bindings version="3.0"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  xmlns:jxb="https://jakarta.ee/xml/ns/jaxb"
  xmlns:xjc1="http://jakarta.ee/xml/ns/jaxb/xjc"
  xmlns:xjc="http://java.sun.com/xml/ns/jaxb/xjc"
  jxb:extensionBindingPrefixes="xjc"
  >
  
  <jxb:globalBindings>
    <jxb:javaType xmlType="xs:integer" name="java.lang.Integer"/>
  </jxb:globalBindings>

  <jxb:bindings schemaLocation="Channel.xsd" node="//xs:element[@name='Channel']/xs:complexType">
    <jxb:class name="Channel" implClass="Channel"/>
      <jxb:extends>Basic</jxb:extends>

      <!--ci:code> implements com.example.MyInterface </ci:code-->
  </jxb:bindings>

  <jxb:bindings schemaLocation="Party.xsd" node="//xs:element[@name='Party']">
      <!--ci:code implements com.example.MyInterface </ci:code-->
  </jxb:bindings>

  <jxb:bindings schemaLocation="Service.xsd" node="//xs:element[@name='Service']">
      <!--ci:code implements com.example.MyInterface </ci:code-->
  </jxb:bindings>

</jxb:bindings>
