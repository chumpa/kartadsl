@startdot
digraph G {
    rankdir=LR;                 // Горизонтальное расположение (слева-направо)
    bgcolor="#F5F5F5";          // Светло-серый фон
    fontname="Arial";
    fontsize=12;
    label="Схема обмена ICo";
    labelloc="t";               // Метка сверху
    fontcolor="#333333";
    compound=true;              // Разрешить ребрам соединять кластеры
    node [
        fontname="Arial",
        fontsize=11,
        shape=box,
        style="rounded, filled",
        fillcolor="#E8E8E8",
        color="#666666",
        penwidth=1.5
    ];
    edge [
        fontname="Arial",
        fontsize=10,
        color="#555555",
        penwidth=1.5,
        arrowsize=0.8
    ];
  START [shape=circle, label="start", fillcolor="#3498DB", fontcolor="white", width=0.6, fixedsize=true];
subgraph receiver_determination {
label="Определение получателя";
        style="filled";
        color="#27AE60";
        bgcolor="#E9F7EF";
        fontcolor="#1E8449";
        fontname="Arial";
    a2da8f537aa911f1cfca000007572072[label="|AE2100"];
    a2da8f527aa911f1a5ee000007572072[label="|AHD100", fillcolor="red"];
    a2da8f547aa911f19e56000007572072[label="|BC_Test"];
    a2da8f557aa911f198ec000007572072[label="P_TEST|BC_Test"];
}
}
@enddot
